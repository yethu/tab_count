{
  "manifest_version": 3,
  "name": "Tab Count",
  "version": "1.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "{06bf8c37-c403-4b6e-8ad7-ea164a42f344}",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "description": "Displays the total number of open tabs across all windows as a badge on the extension icon.",
  "permissions": [
    "tabs"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "action": {
    "default_title": "Tab Count",
    "default_icon": "icons/123.svg"
  },
  "icons": {
    "16": "icons/123.svg",
    "48": "icons/123.svg",
    "96": "icons/123.svg"
  }
}
